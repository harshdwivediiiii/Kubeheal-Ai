{
  "title": "KubeHeal AI Dashboard",
  "uid": "kubeheal",
  "version": 1,
  "panels": [
    {
      "title": "Cluster CPU Usage",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total[5m])) by (pod)"
        }
      ],
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8}
    },
    {
      "title": "Cluster Memory Usage",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes) by (pod)"
        }
      ],
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8}
    },
    {
      "title": "Pod Restart Count",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_restarts_total)"
        }
      ],
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 6}
    },
    {
      "title": "Failed Pods",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{phase=~\"Failed|CrashLoopBackOff\"})"
        }
      ],
      "gridPos": {"x": 8, "y": 8, "w": 8, "h": 6}
    },
    {
      "title": "Network Traffic",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total[5m])) by (pod)"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total[5m])) by (pod)"
        }
      ],
      "gridPos": {"x": 16, "y": 8, "w": 8, "h": 6}
    }
  ]
}
